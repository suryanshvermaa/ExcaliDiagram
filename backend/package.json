{
  "name": "backend",
  "version": "1.0.0",
  "description": "Icon server with MongoDB + S3/MinIO storage",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate-svgs": "node scripts/generateSvgs.js",
    "seed": "node scripts/seed.js",
    "seed:dry": "node scripts/seed.js --dry-run",

    "import:techicons": "node scripts/importIconifyPacks.js --config scripts/iconify.packs.json",
    "import:techicons:k8s": "node scripts/importKubernetesCommunityIcons.js",
    "seed:techicons": "node scripts/seedTechIcons.js",
    "seed:techicons:dry": "node scripts/seedTechIcons.js --dry-run",
    "seed:techicons:force": "node scripts/seedTechIcons.js --force"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^6.0.1",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "langchain": "^1.4.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.39.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
