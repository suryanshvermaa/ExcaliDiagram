# ── App ────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/icons-db

# ── Storage mode ──────────────────────────────────────────────────────────────
# Set USE_S3=true to use real AWS S3 (production)
# Set USE_S3=false (default) to use local MinIO
USE_S3=false
S3_BUCKET=icons
S3_REGION=us-east-1
SIGNED_URL_EXPIRY=3600

# ── MinIO (local dev) ─────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Public base URL that the browser can reach (may differ inside docker)
MINIO_PUBLIC_URL=http://localhost:9000

# ── AWS S3 (production — only needed when USE_S3=true) ────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
